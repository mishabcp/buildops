{
  "name": "buildops-server",
  "version": "1.0.0",
  "description": "Buildops Backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "prisma generate --schema=../prisma/schema.prisma",
    "prisma:migrate": "cd .. && prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema=../prisma/schema.prisma"
  },
  "prisma": {
    "seed": "node ../prisma/seed.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
